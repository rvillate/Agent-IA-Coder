const IGNORE = new Set(['node_modules','.git','dist','build','.next','.angular','target','coverage','.idea','.vscode'])
const DONE_EXT = new Set(['.js','.jsx','.ts','.tsx','.mjs','.cjs','.json','.md','.txt','.css','.scss','.html','.htm','.xml','.yml','.yaml','.py','.java','.cs','.sql','.env','.sh','.bat','.ps1'])
const OP = /&&|\|\||[|<>;]/
const DANGER = /(rm\s+-rf|format\s|shutdown|reboot|del\s+\/s|reg\s+delete|diskpart|mkfs|powershell\s+-enc)/i

const tail = (v,m) => String(v ?? '').length <= m ? String(v ?? '') : String(v ?? '').slice(-m)
const rel = (guard,p) => guard.relativeSafe ? guard.relativeSafe(p) : (path.relative(guard.root,p).replaceAll(path.sep,'/') || '.')
async function exists(p){try{await fs.access(p);return true}catch{return false}}
function mode(stat){return (stat.mode & 0o777).toString(8).padStart(3,'0')}
function item(guard,full,ent,stat){return {path:rel(guard,full),name:ent.name,type:stat.isDirectory()?'directory':'file',size:stat.size,modifiedAt:Math.round(stat.mtimeMs),createdAt:Math.round(stat.birthtimeMs),accessedAt:Math.round(stat.atimeMs),mode:stat.mode,permissions:mode(stat),uid:Number.isInteger(stat.uid)?stat.uid:null,gid:Number.isInteger(stat.gid)?stat.gid:null,isHidden:ent.name.startsWith('.')}}
async function walk(guard,dir,opt,depth=0,out=[]){if(depth>opt.maxDepth||out.length>=opt.maxEntries)return out;for(const ent of await fs.readdir(dir,{withFileTypes:true})){if(out.length>=opt.maxEntries)break;if(!opt.showIgnored&&opt.ignore.has(ent.name))continue;if(!opt.showHidden&&ent.name.startsWith('.'))continue;const full=path.join(dir,ent.name);let stat;try{stat=await fs.stat(full)}catch{continue}out.push(item(guard,full,ent,stat));if(ent.isDirectory())await walk(guard,full,opt,depth+1,out)}return out}

export async function fileList(payload,guard){const target=guard.resolveSafe(payload.path||'.');const opt={maxDepth:Math.min(Number(payload.maxDepth??3),12),maxEntries:Math.min(Number(payload.maxEntries??500),10000),showHidden:Boolean(payload.showHidden),showIgnored:Boolean(payload.showIgnored),ignore:new Set([...(payload.ignore||[]),...IGNORE].map(String))};const items=await walk(guard,target,opt);return{path:rel(guard,target),items,total:items.length,truncated:items.length>=opt.maxEntries}}
export async function fileRead(payload,guard){if(typeof payload.path!=='string')throw new Error('payload.path requerido');const target=guard.resolveSafe(payload.path);const max=Math.min(Number(payload.maxBytes??128000),Number(payload.maxBytesLimit??20*1024*1024));const stat=await fs.stat(target);if(!stat.isFile())throw new Error('La ruta no es un archivo');const buf=await fs.readFile(target);const slice=buf.subarray(0,Math.min(buf.length,max));const enc=String(payload.encoding||'utf8').toLowerCase();return{path:rel(guard,target),content:enc==='base64'?slice.toString('base64'):slice.toString(enc),encoding:enc,size:stat.size,bytesRead:slice.length,sha256:crypto.createHash('sha256').update(slice).digest('hex'),truncated:stat.size>max,modifiedAt:Math.round(stat.mtimeMs),permissions:mode(stat)}}
function toBuffer(payload){if(typeof payload.contentBase64==='string')return{buffer:Buffer.from(payload.contentBase64,'base64'),encoding:'base64'};if(typeof payload.base64==='string')return{buffer:Buffer.from(payload.base64,'base64'),encoding:'base64'};if(typeof payload.content==='string')return{buffer:Buffer.from(payload.content,payload.encoding||'utf8'),encoding:payload.encoding||'utf8'};throw new Error('payload.content, payload.contentBase64 o payload.base64 requerido')}
function parseMode(v){if(v==null||v==='')return null;if(typeof v==='number')return v;if(typeof v==='string')return Number.parseInt(v,8);return null}
export async function fileWrite(payload,guard){if(typeof payload.path!=='string'||!payload.path.trim())throw new Error('payload.path requerido');const target=guard.resolveSafe(payload.path);const {buffer,encoding}=toBuffer(payload);if(payload.createDirs!==false)await fs.mkdir(path.dirname(target),{recursive:true});const existed=await exists(target);if(existed&&payload.overwrite===false&&!payload.append)throw new Error('Archivo ya existe y overwrite=false: '+payload.path);let backupPath=null;if(existed&&payload.backup){const suffix=typeof payload.backup==='string'?payload.backup:'.bak-'+Date.now();backupPath=target+suffix;await fs.copyFile(target,backupPath)}if(payload.append){await fs.appendFile(target,buffer)}else if(payload.atomic!==false){const tmp=path.join(path.dirname(target),'.'+path.basename(target)+'.'+process.pid+'.'+Date.now()+'.tmp');await fs.writeFile(tmp,buffer);await fs.rename(tmp,target)}else{await fs.writeFile(target,buffer)}const m=parseMode(payload.mode);if(m!=null&&Number.isFinite(m))await fs.chmod(target,m);const stat=await fs.stat(target);return{path:rel(guard,target),size:stat.size,bytesWritten:buffer.length,encoding,append:Boolean(payload.append),atomic:payload.atomic!==false&&!payload.append,backupPath:backupPath?rel(guard,backupPath):null,sha256:crypto.createHash('sha256').update(buffer).digest('hex'),permissions:mode(stat),modifiedAt:Math.round(stat.mtimeMs),message:'Archivo escrito correctamente'}}
export async function fileMkdir(payload,guard){if(typeof payload.path!=='string')throw new Error('payload.path requerido');const target=guard.resolveSafe(payload.path);await fs.mkdir(target,{recursive:true});return{path:rel(guard,target),message:'Carpeta creada correctamente'}}
export async function fileDelete(payload,guard,config){if(!config.allowDelete)throw new Error('file.delete bloqueado. Activa RUNNER_ALLOW_DELETE=true para permitirlo.');if(typeof payload.path!=='string')throw new Error('payload.path requerido');const target=guard.resolveSafe(payload.path);const stat=await fs.stat(target);if(stat.isDirectory())await fs.rm(target,{recursive:true,force:true});else await fs.unlink(target);return{path:rel(guard,target),message:'Ruta eliminada correctamente'}}
export async function fileSearch(payload,guard){const root=guard.resolveSafe(payload.path||'.');const q=String(payload.query||'');if(!q)throw new Error('payload.query requerido');const max=Math.min(Number(payload.maxMatches??100),1000);const maxBytes=Math.min(Number(payload.maxFileBytes??512000),5*1024*1024);const cs=Boolean(payload.caseSensitive);const needle=cs?q:q.toLowerCase();const res=[];async function scan(dir,d=0){if(d>12||res.length>=max)return;for(const ent of await fs.readdir(dir,{withFileTypes:true}).catch(()=>[])){if(res.length>=max)break;if(IGNORE.has(ent.name))continue;if(!payload.showHidden&&ent.name.startsWith('.'))continue;const full=path.join(dir,ent.name);if(ent.isDirectory()){await scan(full,d+1);continue}const ext=path.extname(ent.name).toLowerCase();if(!DONE_EXT.has(ext)&&!payload.includeAllTextLike)continue;const stat=await fs.stat(full).catch(()=>null);if(!stat||stat.size>maxBytes)continue;const txt=await fs.readFile(full,'utf8').catch(()=>'');const hay=cs?txt:txt.toLowerCase();const i=hay.indexOf(needle);if(i>=0)res.push({path:rel(guard,full),preview:txt.slice(Math.max(0,i-120),Math.min(txt.length,i+q.length+120)),index:i})}}await scan(root);return{query:q,matches:res,total:res.length,truncated:res.length>=max}}

function commandBase(c){return path.basename(String(c||'').trim()).toLowerCase().replace(/\.exe$/,'')}
function splitLine(s){const input=String(s||'').trim();const tokens=[];let cur='',q=null;for(let i=0;i<input.length;i++){const ch=input[i],nx=input[i+1];if(ch==='\\'&&q&&(nx===q||nx==='\\')){cur+=nx;i++;continue}if(q){if(ch===q)q=null;else cur+=ch;continue}if(ch==='"'||ch==="'"){q=ch;continue}if(/\s/.test(ch)){if(cur){tokens.push(cur);cur=''}continue}cur+=ch}if(q)throw new Error('Comando con comillas sin cerrar: '+input);if(cur)tokens.push(cur);return tokens}
function stripHeredocs(s){const lines=String(s||'').split(/\r?\n/);let out=[],delim=null;for(const line of lines){if(delim){if(line.trim()===delim){delim=null;out.push(line)}continue}out.push(line);const m=line.match(/<<-?\s*['"]?([A-Za-z0-9_.-]+)['"]?/);if(m)delim=m[1]}return out.join('\n')}
function shellSegments(s){const input=stripHeredocs(s);const seg=[];let cur='',q=null;for(let i=0;i<input.length;i++){const ch=input[i],nx=input[i+1];if(ch==='\\'&&q&&(nx===q||nx==='\\')){cur+=ch+nx;i++;continue}if(q){cur+=ch;if(ch===q)q=null;continue}if(ch==='"'||ch==="'"){q=ch;cur+=ch;continue}const two=ch+nx;if(two==='&&'||two==='||'){if(cur.trim())seg.push(cur.trim());cur='';i++;continue}if(ch==='|'||ch===';'){if(cur.trim())seg.push(cur.trim());cur='';continue}cur+=ch}if(cur.trim())seg.push(cur.trim());return seg}
function assertExec(c,config){const base=commandBase(c);if(!base)throw new Error('payload.command requerido');if(config.allowAllCommands)return;if(!config.commandAllowlist.includes(base))throw new Error('Comando bloqueado por allowlist: '+c+'. Permitidos: '+config.commandAllowlist.join(', '))}
function assertAllowed(c,args,config,shell){if(!c)throw new Error('payload.command requerido');if(!config.allowDangerousCommands&&DANGER.test([c,...args].join(' ')))throw new Error('Comando potencialmente peligroso bloqueado: '+c);if(shell){const execs=shellSegments(c).map(x=>splitLine(x)[0]).filter(Boolean);if(!execs.length)throw new Error('payload.command requerido');for(const e of execs)assertExec(e,config)}else assertExec(c,config)}
function normalize(payload){const raw=String(payload.command||'').trim();if(!raw)throw new Error('payload.command requerido');if(payload.shell||OP.test(raw))return{command:raw,args:[],cwdInput:payload.cwd??payload.path??'.',shell:true};if(Array.isArray(payload.args))return{command:raw,args:payload.args.map(String),cwdInput:payload.cwd??payload.path??'.',shell:false};const t=splitLine(raw);return{command:t[0],args:t.slice(1),cwdInput:payload.cwd??payload.path??'.',shell:false}}
export async function runCommand(payload,guard,config,jobId){const n=normalize(payload);assertAllowed(n.command,n.args,config,n.shell);const cwd=guard.resolveSafe(n.cwdInput);const timeoutMs=Math.min(Number(payload.timeoutMs??120000),30*60*1000);await fs.mkdir(config.logDir,{recursive:true});const logPath=path.join(config.logDir,jobId+'.log');const log=fsSync.createWriteStream(logPath,{flags:'a'});return await new Promise(resolve=>{let stdout='',stderr='',finished=false;const started=Date.now();const child=spawn(n.command,n.args,{cwd,shell:n.shell,windowsHide:false});const timer=setTimeout(()=>{child.kill('SIGTERM');log.write('\n[TIMEOUT after '+timeoutMs+'ms]\n');done({status:'timeout',exitCode:null,stdoutTail:tail(stdout,config.maxOutputChars),stderrTail:tail(stderr,config.maxOutputChars),summary:'Comando superó timeout de '+timeoutMs+'ms',localLogPath:logPath,truncated:stdout.length>config.maxOutputChars||stderr.length>config.maxOutputChars,durationMs:Date.now()-started})},timeoutMs);child.stdout?.on('data',c=>{const t=c.toString();stdout+=t;stdout=tail(stdout,config.maxOutputChars*2);log.write(t)});child.stderr?.on('data',c=>{const t=c.toString();stderr+=t;stderr=tail(stderr,config.maxOutputChars*2);log.write(t)});child.on('error',e=>{log.write('\n[PROCESS ERROR] '+e.message+'\n');done({status:'error',exitCode:null,stdoutTail:tail(stdout,config.maxOutputChars),stderrTail:tail(stderr+'\n'+e.message,config.maxOutputChars),summary:'Error iniciando comando',error:e.message,localLogPath:logPath,truncated:stdout.length>config.maxOutputChars||stderr.length>config.maxOutputChars,durationMs:Date.now()-started})});child.on('close',code=>{const st=code===0?'success':'error';done({status:st,exitCode:code,stdoutTail:tail(stdout,config.maxOutputChars),stderrTail:tail(stderr,config.maxOutputChars),summary:st==='success'?'Comando ejecutado correctamente':'Comando terminó con exitCode '+code,localLogPath:logPath,truncated:stdout.length>config.maxOutputChars||stderr.length>config.maxOutputChars,durationMs:Date.now()-started})})})}
export async function gitStatus(payload,guard,config,jobId){return runCommand({command:'git',args:['status','--short'],cwd:payload.cwd||payload.path||'.',timeoutMs:payload.timeoutMs||60000,shell:false},guard,config,jobId)}
export async function gitDiff(payload,guard,config,jobId){const args=['diff'];const diffPath=payload.diffPath??payload.file??payload.targetPath;if(diffPath)args.push('--',String(diffPath));return runCommand({command:'git',args,cwd:payload.cwd||payload.path||'.',timeoutMs:payload.timeoutMs||60000,shell:false},guard,config,jobId)}
