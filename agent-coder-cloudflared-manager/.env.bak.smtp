# Configuracion del manager de Cloudflared.
# Este archivo no inicia nada por si solo; lo usa el servicio systemd agent-coder-cloudflared.service.

# Gateway local que Cloudflared publicara.
TUNNEL_URL=http://127.0.0.1:8787

# Health check del gateway. Debe responder antes de iniciar/reiniciar cloudflared.
GATEWAY_HEALTH_URL=http://127.0.0.1:8787/api/health
GATEWAY_WAIT_TIMEOUT_SEC=300
GATEWAY_CHECK_INTERVAL_SEC=5

# Binario de cloudflared.
CLOUDFLARED_BIN=/usr/local/bin/cloudflared
CLOUDFLARED_RESTART_DELAY_SEC=10

# SMTP: completa estos datos reales para recibir la URL nueva.
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=zcgu sccg yppd ohlv
SMTP_FROM=
SMTP_TO=
SMTP_SUBJECT=Nuevo tunnel Cloudflared Orange Pi
