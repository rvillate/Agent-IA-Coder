# Agent Coder Raspberry Gateway / Admin - configuración local

# Puerto y host donde escucha la API y el panel web.
PORT=8787
HOST=0.0.0.0

# Clave para GPT Actions y panel web. Cambia este valor en producción.
AGENT_API_KEY=change-me-agent-key

# Clave compartida con los runners. Debe coincidir con RUNNER_SHARED_KEY de cada runner.
RUNNER_SHARED_KEY=change-me-runner-key

# Archivo JSON que actúa como DB centralizada.
AGENT_DB_FILE=data/agent-coder.central.json

# Carpeta de backups/snapshots simples de la DB.
AGENT_BACKUP_DIR=data/backups

# Máximo de caracteres guardados por stdout/stderr en cada job.
MAX_TAIL_CHARS=24000

# URL pública opcional para OpenAPI. Déjalo vacío para detectar desde la request.
PUBLIC_BASE_URL=

# Si true, /api/health queda público sin x-agent-key.
PUBLIC_HEALTH=true
