:root {
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #172033;
  background: #eef2f7;
}
* { box-sizing: border-box; }
body { margin: 0; font-size: 13px; line-height: 1.35; }
.container { width: min(1280px, calc(100% - 12px)); margin: 6px auto; }
.hero { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 6px; }
.hero p { margin: 2px 0; }
.eyebrow { text-transform: uppercase; letter-spacing: .12em; font-size: 10px; color: #64748b; font-weight: 800; }
h1 { margin: 0; font-size: clamp(22px, 3vw, 34px); line-height: 1.05; }
h2 { margin: 0 0 8px; font-size: 16px; }
.panel, .status-card { background: #fff; border: 1px solid #d9e2ef; border-radius: 10px; padding: 10px; box-shadow: 0 4px 14px rgba(15, 23, 42, .05); margin-bottom: 8px; }
.status-card { display: flex; align-items: center; gap: 6px; min-width: 120px; justify-content: center; padding: 8px 10px; font-weight: 700; }
.dot { display: inline-block; width: 9px; height: 9px; border-radius: 99px; background: #94a3b8; }
.dot.ok { background: #16a34a; }
.dot.bad { background: #dc2626; }
.grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
label { display: flex; flex-direction: column; gap: 4px; font-weight: 700; color: #334155; }
input, select, textarea { width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: 7px 8px; font: inherit; background: #f8fafc; min-height: 32px; }
textarea, pre { font-family: "Cascadia Code", "Fira Code", Consolas, monospace; font-size: 12px; }
textarea { min-height: 150px; resize: vertical; }
.actions { display: flex; gap: 6px; flex-wrap: wrap; align-items: end; }
button { border: 0; border-radius: 8px; background: #0f172a; color: white; padding: 7px 10px; cursor: pointer; font-weight: 800; min-height: 32px; }
button:hover { background: #1e293b; }
pre { white-space: pre-wrap; overflow: auto; max-height: 360px; background: #0f172a; color: #e2e8f0; padding: 10px; border-radius: 10px; margin: 0; }
@media (max-width: 760px) {
  .grid-2, .hero { grid-template-columns: 1fr; display: grid; }
  .container { width: calc(100% - 8px); margin: 4px auto; }
}
